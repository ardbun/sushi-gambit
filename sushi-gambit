local GroupId, MinRank = SETTINGS.Staff.GroupId, SETTINGS.Staff.MinRank
local KnownPlayers, LastPlayerList = {}, nil

local function GetRankInGroup(uid, gid)
    local ok, res = pcall(function()
        return game:HttpGet("https://groups.roblox.com/v2/users/" .. uid .. "/groups/roles")
    end)
    if not ok or not res or res == "" then return nil, "Unknown" end

    for entry in res:gmatch('{"group".-"role".-}') do
        local id = tonumber(entry:match('"group".-"id"%s*:%s*(%d+)'))
        if id == gid then
            return tonumber(entry:match('"rank"%s*:%s*(%d+)')) or 0,
                entry:match('"role".-"name"%s*:%s*"([^"]+)"') or "Unknown"
        end
    end
    return 0, "Unknown"
end

local function CheckStaff(player)
    local uid = player and player.UserId
    if not uid or KnownPlayers[uid] then return end
    KnownPlayers[uid] = "checking"

    task.spawn(function()
        local rank, role = GetRankInGroup(uid, GroupId)
        if rank == nil then KnownPlayers[uid] = nil return end
        KnownPlayers[uid] = player.Name
        if rank >= MinRank and SETTINGS.Staff.Notify then nt(player.Name .. " (" .. role .. ") joined!", "STAFF ALERT", 10) end
    end)
end

local function ScanStaff()
    local present, names = {}, {}
    for _, player in ipairs(Players:GetPlayers()) do
        names[#names + 1] = player.Name
        if player.UserId then present[player.UserId] = true CheckStaff(player) end
    end

    local text = #names > 0 and table.concat(names, ", ") or "None"
    if text ~= LastPlayerList then LastPlayerList = text end
    for uid in pairs(KnownPlayers) do if not present[uid] then KnownPlayers[uid] = nil end end
end

