local chloroHeld=false
scheduler:addLoop("chloroform",TIMINGS.chloroform,function()
	if not SETTINGS.Auto.Chloroform.Enabled then
		if chloroHeld then pcall(function()kr(0x51)end) chloroHeld=false end
		return end
	local char=LocalPlayer.Character
	if not char then
		if chloroHeld then pcall(function()kr(0x51)end) chloroHeld=false end
		return end
	local tool=char:FindFirstChild("Chloroform Spray")
	if not tool then
		if chloroHeld then pcall(function()kr(0x51)end) chloroHeld=false end
		return end
	local challenge=tool:FindFirstChild("ChloroformChallenge",true)
	if challenge then
		local active=false
		for _,child in ipairs(challenge:GetDescendants())do
			if child:IsA("Frame")and child.Name=="KeyTemplate"and child:GetAttribute("Key") then
				active=true break
			end
		end
		if active then
			pcall(function()kp(0x51)task.wait(0.01)kr(0x51)end)
		else
			if chloroHeld then pcall(function()kr(0x51)end) chloroHeld=false end
		end
	else
		if chloroHeld then pcall(function()kr(0x51)end) chloroHeld=false end
	end
end)
