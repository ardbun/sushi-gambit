local function showAlert(msg, color, key)
    if _alertDrawings[key] then pcall(function() _alertDrawings[key]:Remove() end) end
    local t = Drawing.new("Text")
    t.Text=msg; t.Size=25; t.Color=color or Color3.new(1,1,1)
    t.Outline=true; t.Center=true
    t.Position = Vector2.new(workspace.CurrentCamera.ViewportSize.X/2, 140)
    t.Visible=true
    _alertDrawings[key] = t
end

local function removeAlert(key)
    if _alertDrawings[key] then
        pcall(function() _alertDrawings[key]:Remove() end)
        _alertDrawings[key] = nil
    end
end

