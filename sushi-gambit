-- ─── NPC loop (lifecycle + prompts + ESP tagging — single place) ───────────────

App:addLoop("npc", 0.2, function()
    if not isrbxactive() then return end
    local dest   = workspace:FindFirstChild("NpcDestination")
    local folder = dest and dest:FindFirstChild("SpawnedNPCs")
    if not folder then return end

    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local seen = {}
    local criticSeen, inspectorSeen = false, false

    for _, npc in ipairs(folder:GetChildren()) do
        local addr = npc.Address
        if not addr then continue end
        seen[addr] = true

        -- Register new NPC
        if not NPC.cache[addr] then
            NPC.cache[addr] = {
                inst     = npc,
                head     = npc:FindFirstChild("Head"),
                torso    = npc:FindFirstChild("Torso"),
                humanoid = npc:FindFirstChild("Humanoid"),
            }
        end

        local cached = NPC.cache[addr]

        if not (cached.head  and cached.head.Parent)  then cached.head     = npc:FindFirstChild("Head")     end
        if not (cached.torso and cached.torso.Parent) then cached.torso    = npc:FindFirstChild("Torso")    end
        if not cached.humanoid                         then cached.humanoid = npc:FindFirstChild("Humanoid") end

        local hum = cached.humanoid
        if not npc.Parent
            or (hum and type(hum.Health) == "number" and hum.Health <= 0)
        then
            npcRemove(addr)
            continue
        end

        local torso = cached.torso
        if torso and root and (torso.Position - root.Position).Magnitude < 60 then
            if npc:GetAttribute("CurrentState") == "WaitingInLine" then
                local wp = torso:FindFirstChild("WaitProximityPrompt")
                if wp and wp.Address then pcall(memory_write, "float", wp.Address + HoldDuration, 0) end
            end
            local dp = torso:FindFirstChild("CatchDasherPrompt")
            if dp and dp.Address then pcall(memory_write, "float", dp.Address + HoldDuration, 0) end
        end

        local isDasher    = torso and torso:FindFirstChild("CatchDasherPrompt") ~= nil
        local isCritic    = npc:GetAttribute("Critic") == true
        local isInspector = npc:GetAttribute("Behavior") == "Inspector"

        if isCritic    then criticSeen    = true end
        if isInspector then inspectorSeen = true end

        if (isCritic or isInspector) and not _alerted[addr] then
            _alerted[addr] = true
            if isInspector then
                showAlert("health inspector present", Color3.fromRGB(0,255,0), "inspector")
            else
                showAlert("critic is present", Color3.fromRGB(255,252,0), "critic")
            end
        end
        if not (isCritic or isInspector) then _alerted[addr] = nil end

        local desiredType, desiredColor
        if isDasher and ESP.Dasher.Enabled then
            desiredType  = "Dasher"
            desiredColor = ESP.Dasher.Color
        elseif isCritic and ESP.Critic.Enabled then
            desiredType  = "Critic"
            desiredColor = ESP.Critic.Color
        elseif isInspector and ESP.HealthInspector.Enabled then
            desiredType  = "HealthInspector"
            desiredColor = ESP.HealthInspector.Color
        end

        local ent = NPC.entities[addr]
        if desiredType then
            if not ent or ent.Type ~= desiredType then
                if ent then ent:Destroy() end
                NPC.entities[addr] = Entity.new(npc, desiredType, desiredColor)
            end
        else
            if ent then ent:Destroy(); NPC.entities[addr] = nil end
        end
    end

    for addr in pairs(NPC.cache) do
        if not seen[addr] then
            _alerted[addr] = nil
            npcRemove(addr)
        end
    end

    if not criticSeen    then removeAlert("critic")    end
    if not inspectorSeen then removeAlert("inspector") end
end)

App:addLoop("espRender", 0.016, function()
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    for addr, ent in pairs(NPC.entities) do
        if ent.State == STATE.DESTROYED then
            NPC.entities[addr] = nil
            continue
        end
        local cached = NPC.cache[addr]
        if not cached then ent:Destroy(); NPC.entities[addr] = nil; continue end

        local head = cached.head
        if not head or not head.Parent then ent:Hide(); continue end

        local hum = cached.humanoid
        if hum and type(hum.Health) == "number" and hum.Health <= 0 then ent:Hide(); continue end

        if root and (head.Position - root.Position).Magnitude > ESP.MAX_DIST then ent:Hide(); continue end

        local cfg = ESP[ent.TypeKey]
        if not cfg or not cfg.Enabled then ent:Hide(); continue end

        ent:SetColor(cfg.Color)
        local pos, onScreen = WorldToScreen(head.Position + Vector3.new(0, 1.5, 0))
        if onScreen then ent:Show(pos) else ent:Hide() end
    end
end)

