local function getOffset(tbl, ...)
    local cur = tbl
    for _, k in ipairs({...}) do
        if type(cur) ~= "table" or cur[k] == nil then return nil end
        cur = cur[k]
    end
    return tonumber(cur, 16)
end

local ScreenGuiEnabled = getOffset(raw, "Offsets", "GuiObject", "ScreenGui_Enabled") or 0x4cc
local HoldDuration = getOffset(raw, "Offsets", "ProximityPrompt", "HoldDuration") or 0x138
local PromptEnabled = getOffset(raw, "Offsets", "ProximityPrompt", "Enabled") or 0x14e

local function safePath(root, ...)
    local cur = root
    for _, k in ipairs({...}) do
        if not cur then return nil end
        cur = cur:FindFirstChild(k)
    end
    return cur
end

local function zeroPrompt(instance, promptName)
    local torso = instance:FindFirstChild("Torso")
    local prompt = torso and torso:FindFirstChild(promptName)
    if prompt and prompt.Address then
        memory_write("float", prompt.Address + HoldDuration, 0)
        return true
    end
    return false
end

