local scheduler = {_loops = {}}

function scheduler:addLoop(name, interval, fn)
    if self._loops[name] then warn("scheduler: overwriting loop '" .. name .. "'") end
    self._loops[name] = {interval = interval, timer = 0, fn = fn}
end

function scheduler:remove(name)
    self._loops[name] = nil
end

local Connections = {}

table.insert(Connections, RunService.Heartbeat:Connect(function(dt)
    for name, job in pairs(scheduler._loops) do
        job.timer = job.timer + dt
        if job.timer >= job.interval then
            job.timer = job.timer - job.interval
            task.spawn(function()
                local ok, err = pcall(job.fn)
                if not ok then
                    warn("scheduler job '" .. name .. "' errored: " .. tostring(err))
                end
            end)
        end
    end
end))

local Lib = {}
Lib.__index = Lib

function Lib.new(titleText, width, height, cornerRadius)
    local self = setmetatable({}, Lib)
    local r = cornerRadius or 10
    local w, h = width or 260, height or 130

    self.Elements = {}
    self.Labels = {}
    self.Radius = r
    self.Position = Vector2.new(100, 100)
    self.Size = Vector2.new(w, h)

    local bg = Color3.fromRGB(15, 15, 15)

    local function newCircle(pos)
        local c = Drawing.new("Circle")
        c.Position = pos
        c.Radius = r
        c.Color = bg
        c.Filled = true
        c.Visible = false
        c.NumSides = 64
        table.insert(self.Elements, c)
        return c
    end

    local function newRect(pos, size)
        local s = Drawing.new("Square")
        s.Position = pos
        s.Size = size
        s.Color = bg
        s.Filled = true
        s.Visible = false
        table.insert(self.Elements, s)
        return s
    end

    self.TopLeft = newCircle(self.Position + Vector2.new(r, r))
    self.TopRight = newCircle(self.Position + Vector2.new(w - r, r))
    self.BottomLeft = newCircle(self.Position + Vector2.new(r, h - r))
    self.BottomRight = newCircle(self.Position + Vector2.new(w - r, h - r))
    self.VerticalFill = newRect(self.Position + Vector2.new(r, 0), Vector2.new(w - 2 * r, h))
    self.HorizontalFill = newRect(self.Position + Vector2.new(0, r), Vector2.new(w, h - 2 * r))

    local title = Drawing.new("Text")
    title.Text = titleText
    title.Size = 12
    title.Position = self.Position + Vector2.new(12, 15)
    title.Color = Color3.fromRGB(255, 0, 0)
    title.Outline = true
    title.Visible = false
    self.Title = title
    table.insert(self.Elements, title)

    return self
end

function Lib:Show(visible)
    for _, v in ipairs(self.Elements) do v.Visible = visible end
    for _, v in ipairs(self.Labels) do v.drawing.Visible = visible end
end

function Lib:Edit(pos, size)
    pos = pos or self.Position
    size = size or self.Size
    self.Position, self.Size = pos, size

    local x, y, w, h, r = pos.X, pos.Y, size.X, size.Y, self.Radius

    self.TopLeft.Position = Vector2.new(x + r, y + r)
    self.TopRight.Position = Vector2.new(x + w - r, y + r)
    self.BottomLeft.Position = Vector2.new(x + r, y + h - r)
    self.BottomRight.Position = Vector2.new(x + w - r, y + h - r)
    self.VerticalFill.Position = Vector2.new(x + r, y)
    self.VerticalFill.Size = Vector2.new(w - 2 * r, h)
    self.HorizontalFill.Position = Vector2.new(x, y + r)
    self.HorizontalFill.Size = Vector2.new(w, h - 2 * r)
    self.Title.Position = Vector2.new(x + 12, y + 15)

    for _, entry in ipairs(self.Labels) do
        entry.drawing.Position = pos + entry.relPos
    end
end

function Lib:Delete()
    for _, v in ipairs(self.Elements) do v:Remove() end
    for _, v in ipairs(self.Labels) do v.drawing:Remove() end
    self.Elements = {}
    self.Labels = {}
end

local LABEL_START_Y, LABEL_STEP = 32, 20

function Lib:AddLabel(text, color)
    local d = Drawing.new("Text")
    d.Text = text or ""
    d.Size = 20
    d.Color = color or Color3.new(1, 1, 1)
    d.Outline = true
    d.Visible = true

    local entry = {drawing = d, relPos = Vector2.new(12, 0)}
    table.insert(self.Labels, entry)

    for i, e in ipairs(self.Labels) do
        e.relPos = Vector2.new(12, LABEL_START_Y + (i - 1) * LABEL_STEP)
        e.drawing.Position = self.Position + e.relPos
    end

    local handle = {}
    function handle:SetText(t) d.Text = t end
    function handle:Delete()
        d:Remove()
        for i, e in ipairs(self.Labels) do
            if e == entry then table.remove(self.Labels, i) break end
        end
    end
    return handle
end

