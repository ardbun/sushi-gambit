local scheduler, Connections = {_loops = {}}, {}
function scheduler:addLoop(n, i, f) if self._loops[n] then warn("overwriting '"..n.."'") end self._loops[n] = {interval = i, timer = 0, fn = f} end
function scheduler:remove(n) self._loops[n] = nil end

table.insert(Connections, RunS.Heartbeat:Connect(function(dt)
    for n, j in pairs(scheduler._loops) do
        j.timer = j.timer + dt
        if j.timer >= j.interval then
            j.timer = j.timer - j.interval
            task.spawn(function() local ok, err = pcall(j.fn) if not ok then warn("job '"..n.."' errored: "..tostring(err)) end end)
        end
    end
end))

local Lib = {}
Lib.__index = Lib
function Lib.new(t, w, h, r)
    local self = setmetatable({}, Lib)
    r, w, h = r or 10, w or 260, h or 130
    self.Elements, self.Labels, self.Radius, self.Position, self.Size = {}, {}, r, Vector2.new(100,100), Vector2.new(w,h)
    local bg = Color3.fromRGB(15,15,15)
    local function nc(p) local c = Drawing.new("Circle") c.Position,c.Radius,c.Color,c.Filled,c.Visible,c.NumSides = p,r,bg,true,false,64 table.insert(self.Elements, c) return c end
    local function nr(p,s) local sq = Drawing.new("Square") sq.Position,sq.Size,sq.Color,sq.Filled,sq.Visible = p,s,bg,true,false table.insert(self.Elements, sq) return sq end
    self.TL,self.TR,self.BL,self.BR = nc(self.Position+Vector2.new(r,r)), nc(self.Position+Vector2.new(w-r,r)), nc(self.Position+Vector2.new(r,h-r)), nc(self.Position+Vector2.new(w-r,h-r))
    self.VF,self.HF = nr(self.Position+Vector2.new(r,0), Vector2.new(w-2*r,h)), nr(self.Position+Vector2.new(0,r), Vector2.new(w,h-2*r))
    self.Title = Drawing.new("Text") self.Title.Text,self.Title.Size,self.Title.Position,self.Title.Color,self.Title.Outline,self.Title.Visible = t,12,self.Position+Vector2.new(12,15),Color3.fromRGB(255,0,0),true,false
    table.insert(self.Elements, self.Title)
    return self
end
function Lib:Show(v) for _,e in ipairs(self.Elements) do e.Visible = v end for _,l in ipairs(self.Labels) do l.drawing.Visible = v end end
function Lib:Edit(p,s)
    p,s = p or self.Position, s or self.Size
    self.Position, self.Size = p, s
    local x,y,w,h,r = p.X,p.Y,s.X,s.Y,self.Radius
    self.TL.Position,self.TR.Position,self.BL.Position,self.BR.Position = Vector2.new(x+r,y+r), Vector2.new(x+w-r,y+r), Vector2.new(x+r,y+h-r), Vector2.new(x+w-r,y+h-r)
    self.VF.Position,self.VF.Size,self.HF.Position,self.HF.Size = Vector2.new(x+r,y), Vector2.new(w-2*r,h), Vector2.new(x,y+r), Vector2.new(w,h-2*r)
    self.Title.Position = Vector2.new(x+12,y+15)
    for _,e in ipairs(self.Labels) do e.drawing.Position = p + e.relPos end
end
function Lib:Delete() for _,v in ipairs(self.Elements) do v:Remove() end for _,v in ipairs(self.Labels) do v.drawing:Remove() end self.Elements,self.Labels = {},{} end
function Lib:AddLabel(t,c)
    local d = Drawing.new("Text") d.Text,d.Size,d.Color,d.Outline,d.Visible = t or "",20,c or Color3.new(1,1,1),true,true
    local entry = {drawing = d, relPos = Vector2.new(12,0)}
    table.insert(self.Labels, entry)
    for i,e in ipairs(self.Labels) do e.relPos = Vector2.new(12, 32 + (i-1)*20) e.drawing.Position = self.Position + e.relPos end
    local handle = {} function handle:SetText(t) d.Text = t end function handle:Delete() d:Remove() for i,e in ipairs(self.Labels) do if e == entry then table.remove(self.Labels, i) break end end end return handle
end

