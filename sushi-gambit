local _alertDrawings = {}
local _dasherBar = nil
local _dasherBarText = nil

local function showScreenAlert(message, color, key)
    if _alertDrawings[key] then
        pcall(function() _alertDrawings[key]:Remove() end)
    end
    local text = Drawing.new("Text")
    text.Text = message
    text.Size = 25
    text.Color = color or Color3.new(1, 1, 1)
    text.Outline = true
    text.Center = true
    text.Position = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, 140)
    text.Visible = true
    _alertDrawings[key] = text
end

local function removeScreenAlert(key)
    if _alertDrawings[key] then
        pcall(function() _alertDrawings[key]:Remove() end)
        _alertDrawings[key] = nil
    end
end

local _notifiedNpcs = {}

scheduler:addLoop("npcAlerts", 0.5, function()
    local dest = workspace:FindFirstChild("NpcDestination")
    local folder = dest and dest:FindFirstChild("SpawnedNPCs")
    if not folder then return end

    local criticSeen, inspectorSeen = false, false

    for _, npc in ipairs(folder:GetChildren()) do
        local addr = npc.Address
        if not addr then continue end
        local state = npc:GetAttribute("CurrentState")
local isCritic = npc:GetAttribute("Critic") == true and state ~= "Leaving" and state ~= "Left" and state ~= "Done"
        local isInspector = npc:GetAttribute("Behavior") == "Inspector"

        if isCritic then criticSeen = true end
        if isInspector then inspectorSeen = true end

        if (isCritic or isInspector) and not _notifiedNpcs[addr] then
            _notifiedNpcs[addr] = true
            if isInspector then
                showScreenAlert("health inspector present", Color3.fromRGB(0, 255, 0), "inspector")
            else
                showScreenAlert("critic is present", Color3.fromRGB(255, 252, 0), "critic")
            end
        end

        if not (isCritic or isInspector) then
            _notifiedNpcs[addr] = nil
        end
    end

    if not criticSeen then removeScreenAlert("critic") end
    if not inspectorSeen then removeScreenAlert("inspector") end
end)


scheduler:addLoop("cleanup", 60, function()
    _notifiedNpcs = {}
end)

scheduler:addLoop("dasherBar", 0.3, function()
    local count = 0
    for addr, ent in pairs(Manager.Entities) do
        if ent.Type == "Dasher" and ent.State == STATE.ACTIVE then
            count += 1
        end
    end
    local vp = workspace.CurrentCamera.ViewportSize
    local cx = vp.X / 2
    local cy = vp.Y / 2 + 60
    if count > 0 then
        local label = count == 1 and "dasher" or (tostring(count) .. " dashers")
        if not _dasherBarText then
            _dasherBarText = Drawing.new("Text")
            _dasherBarText.Size = 16
            _dasherBarText.Color = Color3.new(1, 1, 1)
            _dasherBarText.Outline = true
            _dasherBarText.Center = true
            _dasherBarText.Visible = true
        end
        _dasherBarText.Text = label
        _dasherBarText.Position = Vector2.new(cx, cy + 6)
        local bounds = _dasherBarText.TextBounds
        local padX, padY = 16, 8
        if not _dasherBar then
            _dasherBar = Drawing.new("Square")
            _dasherBar.Filled = true
            _dasherBar.Color = Color3.new(0, 0, 0)
            _dasherBar.Transparency = 0.6
            _dasherBar.Visible = true
        end
        local barW = math.max(bounds.X + padX * 2, 100)
        _dasherBar.Size = Vector2.new(barW, bounds.Y + padY * 2)
        _dasherBar.Position = Vector2.new(cx - bounds.X / 2 - padX, cy + 6 - padY)
        _dasherBarText.Visible = true
        _dasherBar.Visible = true
    else
        if _dasherBarText then _dasherBarText.Visible = false end
        if _dasherBar then _dasherBar.Visible = false end
    end
end)
