local scheduler, Connections = { _loops = {} }, {}
local alertDrawings, notifiedNpcs = {}, {}

function scheduler:addLoop(name, interval, fn)
    self._loops[name] = { interval = interval, timer = 0, fn = fn, running = false }
end
function scheduler:remove(name) self._loops[name] = nil end
function scheduler:clearAll() for name in pairs(self._loops) do self._loops[name] = nil end end

local function runLoop(name, job)
    if job.running then return end
    job.running = true
    local ok, err = pcall(job.fn)
    job.running = false
    if not ok then warn("job '" .. name .. "': " .. tostring(err)) end
end

Connections[#Connections + 1] = RunS.Heartbeat:Connect(function(dt)
    for name, job in pairs(scheduler._loops) do
        job.timer = job.timer + dt
        if job.timer >= job.interval then
            job.timer = 0
            task.spawn(function()
                runLoop(name, job)
            end)
        end
    end
end)
local function nt(msg, title, duration) pcall(function() notify(msg, title or "", duration or 3) end) end
local function child(obj, ...) for _, name in ipairs({ ... }) do obj = obj and obj:FindFirstChild(name) end return obj end
local function each(obj, fn) if obj then for _, item in ipairs(obj:GetChildren()) do fn(item) end end end
local function val(obj, name, default) obj = obj and obj:FindFirstChild(name) return obj and obj.Value or default or 0 end
local function setVal(obj, name, value) obj = obj and obj:FindFirstChild(name) if obj then pcall(function() obj.Value = value end) end end
local function setPromptHold(prompt) if prompt and prompt.Address then pcall(function() mw("float", prompt.Address + HoldDuration, 0) end) end end

local Windows = {
    Elements = {}, Labels = {}, Position = Vector2.new(1695, 845),
    Size = Vector2.new(195, 230), Ready = false
}

function Windows:Show(state)
    for _, e in ipairs(self.Elements) do e.Visible = state end
    for _, l in ipairs(self.Labels) do l.drawing.Visible = state end
end

function Windows:Edit(pos, size)
    self.Position, self.Size = pos or self.Position, size or self.Size
    local x, y = math.floor(self.Position.X), math.floor(self.Position.Y)
    local w, h = math.floor(self.Size.X), math.floor(self.Size.Y)

    for i, e in ipairs(self.Elements) do
        if i == 1 then e.Position, e.Size = Vector2.new(x, y), Vector2.new(w, h) end
        if i == 2 then e.Position = Vector2.new(x + 12, y + 12) end
    end
    for i, l in ipairs(self.Labels) do
        l.drawing.Position = Vector2.new(x + 12, y + 38 + (i - 1) * 22)
    end
end

function Windows:Delete()
    for _, e in ipairs(self.Elements) do pcall(function() e:Remove() end) end
    for _, l in ipairs(self.Labels) do pcall(function() l.drawing:Remove() end) end
    self.Elements, self.Labels = {}, {}
end

function Windows:AddLabel(text, color)
    local d = Drawing.new("Text")
    d.Text, d.Size, d.Color = text or "", 22, color or Color3.new(1, 1, 1)
    d.Outline, d.Visible, d.Font = true, false, FONT
    d.Position = Vector2.new(self.Position.X + 12, self.Position.Y + 38 + #self.Labels * 22)

    local entry = { drawing = d }
    self.Labels[#self.Labels + 1] = entry

    local handle = {}
    function handle:SetText(t) d.Text = t end
    function handle:Delete()
        pcall(function() d:Remove() end)
        for i, e in ipairs(Windows.Labels) do
            if e == entry then table.remove(Windows.Labels, i) break end
        end
    end
    return handle
end

