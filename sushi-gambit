local function showAlert(message, color, key)
    if alertDrawings[key] then pcall(function() alertDrawings[key]:Remove() end) end

    local text, cam = Drawing.new("Text"), workspace.CurrentCamera
    text.Text, text.Size, text.Color = message, 28, color or Color3.new(1, 1, 1)
    text.Outline, text.Center, text.Font = true, true, FONT
    text.Position = Vector2.new(cam and math.floor(cam.ViewportSize.X / 2) or 960, 144)
    text.Visible, alertDrawings[key] = true, text
end

local function removeAlert(key)
    if alertDrawings[key] then pcall(function() alertDrawings[key]:Remove() end) alertDrawings[key] = nil end
end

scheduler:addLoop("npcAlerts", TIMINGS.npcAlerts, function()
    local folder = child(workspace, "NpcDestination", "SpawnedNPCs")
    if not folder then return end

    local criticSeen, inspectorSeen = false, false
    each(folder, function(npc)
        local addr, state = npc.Address, npc:GetAttribute("CurrentState")
        if not addr then return end

        local isCritic = npc:GetAttribute("Critic") == true and state ~= "Leaving" and state ~= "Left" and state ~= "Done"
        local isInspector = npc:GetAttribute("Behavior") == "Inspector"
        criticSeen, inspectorSeen = criticSeen or isCritic, inspectorSeen or isInspector

        if (isCritic or isInspector) and not notifiedNpcs[addr] then
            notifiedNpcs[addr] = true
            if isInspector then showAlert("health inspector", Color3.fromRGB(0, 255, 0), "inspector") end
            if isCritic then showAlert("critic", Color3.fromRGB(255, 252, 0), "critic") end
        elseif not (isCritic or isInspector) then
            notifiedNpcs[addr] = nil
        end
    end)

    if not criticSeen then removeAlert("critic") end
    if not inspectorSeen then removeAlert("inspector") end
end)

