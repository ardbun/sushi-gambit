local RankCache = {}

local function getGroupRank(userId)
    if RankCache[userId] then
        return RankCache[userId].rank, RankCache[userId].role
    end

    local url = "https://groups.roblox.com/v2/users/" .. userId .. "/groups/roles"
    local success, response = pcall(game.HttpGet, game, url)
    if not success then
        RankCache[userId] = {rank = 0, role = "Unknown"}
        return 0, "Unknown"
    end

    local ok, data = pcall(function()
        return HttpService:JSONDecode(response)
    end)

    if not ok or not data or not data.data then
        RankCache[userId] = {rank = 0, role = "Unknown"}
        return 0, "Unknown"
    end

    for _, group in pairs(data.data) do
        if group.group and group.group.id == SETTINGS.StaffGroupId then
            RankCache[userId] = {rank = group.role.rank, role = group.role.name}
            return group.role.rank, group.role.name
        end
    end
    RankCache[userId] = {rank = 0, role = "Unknown"}
    return 0, "Unknown"
end

