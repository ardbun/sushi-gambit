local STATE = {ACTIVE=1, DESTROYED=2}

local Entity = {}
Entity.__index = Entity

function Entity.new(npc, typeName, color)
    local text = Drawing.new("Text")
    text.Text=typeName; text.Size=14
    text.Color=color or Color3.new(1,1,1)
    text.Outline=true; text.Visible=false
    return setmetatable({
        inst    = npc,
        text    = text,
        Type    = typeName,
        TypeKey = typeName:gsub(" ",""),
        State   = STATE.ACTIVE,
    }, Entity)
end

function Entity:Show(pos)  self.text.Position=pos; self.text.Visible=true end
function Entity:Hide()     if self.text then self.text.Visible=false end end
function Entity:SetColor(c) if self.text then self.text.Color=c end end

function Entity:Destroy()
    if self.State == STATE.DESTROYED then return end
    self.State = STATE.DESTROYED
    pcall(function() self.text:Remove() end)
end

