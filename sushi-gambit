    if not SETTINGS.Cheat.Instant.SeatCustomer.Enabled then return end

    local folder = getSpawnedNPCs()
    if not folder then return end

    for _, npc in ipairs(folder:GetChildren()) do
        local torso = npc:FindFirstChild("Torso")
        if torso then
            local prompt = torso:FindFirstChild("WaitProximityPrompt")
            if prompt and prompt.Address then
                memory_write("float", prompt.Address + HoldDuration, 0)
            end
        end
    end
end)

scheduler:addLoop("rankCacheClear", TIMINGS.rankCacheClear, function()
    table.clear(RankCache)
end)

local KeyState = {
    X = false,
    Z = false,
}

scheduler:addLoop("keybinds", TIMINGS.keybinds, function()
    local xDown = iskeypressed(0x58)
    local zDown = iskeypressed(0x5A)

    if xDown and not KeyState.X then
        SETTINGS.Auto.ChloroformSpys.Enabled = not SETTINGS.Auto.ChloroformSpys.Enabled
        notify(
            "Auto Chloroform: " .. (SETTINGS.Auto.ChloroformSpys.Enabled and "ON" or "OFF"),
            "Keybind X",
            2
        )
    end

    if zDown and not KeyState.Z then
        SETTINGS.Auto.Washing.Enabled = not SETTINGS.Auto.Washing.Enabled
        notify(
            "Auto Wash: " .. (SETTINGS.Auto.Washing.Enabled and "ON" or "OFF"),
            "Keybind Z",
            2
        )
    end

    KeyState.X = xDown
    KeyState.Z = zDown
end)

notify('script loaded', "", 4)

if getgenv then
    getgenv().SushiGambitCleanup = function()
        for name in pairs(scheduler._loops) do scheduler:remove(name) end
        for _, c in ipairs(Connections) do pcall(function() c:Disconnect() end) end
        pcall(function() Windows:Delete() end)
        for _, d in pairs(_alertDrawings or {}) do pcall(function() d:Remove() end) end
        pcall(function()
            UI.RemoveTab("Sushi Gambit")
        end)
    end
end
