-- ─── App (unified scheduler + connections) ─────────────────────────────────────

local App = {
    _loops       = {},   -- name -> {t, i, fn}
    Connections  = {},
}

function App:addLoop(name, interval, fn)
    self._loops[name] = {t=0, i=interval, fn=fn}
end

function App:removeLoop(name)
    self._loops[name] = nil
end

-- Single Heartbeat drives everything
table.insert(App.Connections, RunService.Heartbeat:Connect(function(dt)
    for _, job in pairs(App._loops) do
        job.t += dt
        if job.t >= job.i then
            job.t -= job.i
            local ok, err = pcall(job.fn)
            if not ok then warn("loop error:", err) end
        end
    end
end))

