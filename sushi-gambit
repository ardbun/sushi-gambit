local Lib = {}
Lib.__index = Lib

function Lib.new(title, w, h, r)
    local self = setmetatable({}, Lib)
    r = r or 10; w = w or 220; h = h or 220
    self.Elements = {}; self.Labels = {}
    self.Radius = r
    self.Position = Vector2.new(100, 100)
    self.Size     = Vector2.new(w, h)
    local bg = Color3.fromRGB(15, 15, 15)

    local function circ(pos)
        local c = Drawing.new("Circle")
        c.Position=pos; c.Radius=r; c.Color=bg
        c.Filled=true; c.Visible=false; c.NumSides=64
        table.insert(self.Elements, c); return c
    end
    local function rect(pos, size)
        local s = Drawing.new("Square")
        s.Position=pos; s.Size=size; s.Color=bg
        s.Filled=true; s.Visible=false
        table.insert(self.Elements, s); return s
    end

    self.TL = circ(self.Position + Vector2.new(r, r))
    self.TR = circ(self.Position + Vector2.new(w-r, r))
    self.BL = circ(self.Position + Vector2.new(r, h-r))
    self.BR = circ(self.Position + Vector2.new(w-r, h-r))
    self.VF = rect(self.Position + Vector2.new(r, 0),  Vector2.new(w-2*r, h))
    self.HF = rect(self.Position + Vector2.new(0, r),  Vector2.new(w, h-2*r))

    local txt = Drawing.new("Text")
    txt.Text=title; txt.Size=12
    txt.Position=self.Position + Vector2.new(12,15)
    txt.Color=Color3.fromRGB(255,0,0); txt.Outline=true; txt.Visible=false
    self.Title = txt
    table.insert(self.Elements, txt)
    return self
end

function Lib:Show(v)
    for _, e in ipairs(self.Elements) do e.Visible = v end
    for _, e in ipairs(self.Labels)   do e.d.Visible = v end
end

function Lib:Edit(pos, size)
    pos  = pos  or self.Position
    size = size or self.Size
    self.Position, self.Size = pos, size
    local x,y,w,h,r = pos.X,pos.Y,size.X,size.Y,self.Radius
    self.TL.Position = Vector2.new(x+r,   y+r)
    self.TR.Position = Vector2.new(x+w-r, y+r)
    self.BL.Position = Vector2.new(x+r,   y+h-r)
    self.BR.Position = Vector2.new(x+w-r, y+h-r)
    self.VF.Position = Vector2.new(x+r, y);  self.VF.Size = Vector2.new(w-2*r, h)
    self.HF.Position = Vector2.new(x, y+r);  self.HF.Size = Vector2.new(w, h-2*r)
    self.Title.Position = Vector2.new(x+12, y+15)
    for _, e in ipairs(self.Labels) do
        e.d.Position = pos + e.rel
    end
end

function Lib:Delete()
    for _, e in ipairs(self.Elements) do pcall(function() e:Remove() end) end
    for _, e in ipairs(self.Labels)   do pcall(function() e.d:Remove() end) end
    self.Elements = {}; self.Labels = {}
end

local LS, LSTEP = 32, 20
function Lib:AddLabel(text, color)
    local d = Drawing.new("Text")
    d.Text=text or ""; d.Size=20
    d.Color=color or Color3.new(1,1,1)
    d.Outline=true; d.Visible=true
    local entry = {d=d, rel=Vector2.new(12,0)}
    table.insert(self.Labels, entry)
    for i, e in ipairs(self.Labels) do
        e.rel = Vector2.new(12, LS+(i-1)*LSTEP)
        e.d.Position = self.Position + e.rel
    end
    local handle = {}
    function handle:SetText(t) d.Text = t end
    function handle:Delete()
        d:Remove()
        for i, e in ipairs(self.Labels) do
            if e == entry then table.remove(self.Labels, i) break end
        end
    end
    return handle
end

