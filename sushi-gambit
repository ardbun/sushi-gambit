local _clockTargets = {["4:40PM"]=true,["4:45PM"]=true,["4:50PM"]=true,["4:55PM"]=true}

local function normalizeClock(t)
    t = t:gsub("%s+",""):gsub("%[",""):gsub("%]",""):gsub("^0","")
    return t:upper()
end

scheduler:addLoop("clock", TIMINGS.clock, function()
    if not _clockLabel then return end
    local norm = normalizeClock(_clockLabel.Text)
    if norm == _clockLastTime then return end
    _clockLastTime = norm
    if _clockTargets[norm] and not _clockWarned[norm] then
        _clockWarned[norm] = true
        notify("remove sun tat", "reminder", 5)
    end
    if norm == "5:05AM" then _clockWarned = {} end
end)

local STATE = {ACTIVE = 1, DESTROYED = 2}

local Entity = {}
Entity.__index = Entity

function Entity.new(instance, typeName, color)
    local text = Drawing.new("Text")
    text.Text    = typeName
    text.Size    = 14
    text.Color   = color or Color3.new(1, 1, 1)
    text.Outline = true
    text.Visible = false
    return setmetatable({
        Instance = instance,
        Head     = instance:FindFirstChild("Head"),
        Text     = text,
        Type     = typeName,
        State    = STATE.ACTIVE,
    }, Entity)
end

function Entity:Update(pos, onScreen)
    if self.State == STATE.DESTROYED then return end
    self.Text.Visible = onScreen
    if onScreen then self.Text.Position = pos end
end

function Entity:Destroy()
    if self.State == STATE.DESTROYED then return end
    self.State = STATE.DESTROYED
    pcall(function() self.Text:Remove() end)
end

function Entity:Hide()
    if self.Text then self.Text.Visible = false end
end

function Entity:SetColor(color)
    if self.Text then self.Text.Color = color end
end

local Manager = {Entities = {}}

function Manager:Add(id, entity) self.Entities[id] = entity end

function Manager:Remove(id)
    local ent = self.Entities[id]
    if not ent then return end
    ent:Destroy()
    self.Entities[id] = nil
end

local npcRegistry = {}

local _knownAddrs = {}

scheduler:addLoop("npcScan", 0.5, function()
    local dest = workspace:FindFirstChild("NpcDestination")
    if not dest then return end
    local folder = dest:FindFirstChild("SpawnedNPCs")
    if not folder then return end

    local seen = {}
    for _, npc in ipairs(folder:GetChildren()) do
        local addr = npc.Address
        if not addr then continue end
        seen[addr] = true
        if not _knownAddrs[addr] then
            _knownAddrs[addr] = true
            npcRegistry[addr] = {
                inst     = npc,
                head     = npc:FindFirstChild("Head"),
                torso    = npc:FindFirstChild("Torso"),
                humanoid = npc:FindFirstChild("Humanoid"),
            }
        end
    end

    for addr in pairs(_knownAddrs) do
        if not seen[addr] then
            Manager:Remove(addr)
            npcRegistry[addr] = nil
            _knownAddrs[addr] = nil
        end
    end
end)

scheduler:addLoop("npcLogic", 0.15, function()
    if not isrbxactive() then return end

    for addr, cached in pairs(npcRegistry) do
        local npc = cached.inst
        if not npc or not npc.Parent then
            Manager:Remove(addr)
            npcRegistry[addr] = nil
            continue
        end

        if not (cached.head   and cached.head.Parent)   then cached.head     = npc:FindFirstChild("Head")     end
        if not (cached.torso  and cached.torso.Parent)  then cached.torso    = npc:FindFirstChild("Torso")    end
        if not cached.humanoid                           then cached.humanoid = npc:FindFirstChild("Humanoid") end

        local hum = cached.humanoid
        if hum and hum.Health and hum.Health <= 0 then
            Manager:Remove(addr)
            continue
        end

        local torso = cached.torso
        if torso then
            local state = npc:GetAttribute("CurrentState")
            if state == "WaitingInLine" then
                local wp = torso:FindFirstChild("WaitProximityPrompt")
                if wp and wp.Address then
                    memory_write("float", wp.Address + HoldDuration, 0)
                end
            end

            local dp = torso:FindFirstChild("CatchDasherPrompt")
            if dp and dp.Address then
                memory_write("float", dp.Address + HoldDuration, 0)
            end
        end

        local isDasher = cached.torso and cached.torso:FindFirstChild("CatchDasherPrompt") ~= nil
        local isCritic = npc:GetAttribute("Critic") == true
        local isInspector = npc:GetAttribute("Behavior") == "Inspector"

        local function syncEntity(condition, typeName, color)
            local ent = Manager.Entities[addr]
            if condition then
                if not ent then
                    Manager:Add(addr, Entity.new(npc, typeName, color))
                end
            else
                if ent and ent.Type == typeName then
                    Manager:Remove(addr)
                end
            end
        end

        if isDasher then
            syncEntity(ESP_SETTINGS.Dasher.Enabled,          "Dasher",           ESP_SETTINGS.Dasher.Color)
        elseif isCritic then
            syncEntity(ESP_SETTINGS.Critic.Enabled,          "Critic",           ESP_SETTINGS.Critic.Color)
        elseif isInspector then
            syncEntity(ESP_SETTINGS.HealthInspector.Enabled, "Health Inspector", ESP_SETTINGS.HealthInspector.Color)
        else
            Manager:Remove(addr)
        end
    end
end)

RunService.Heartbeat:Connect(function()
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    for id, entity in pairs(Manager.Entities) do
        if entity.State == STATE.DESTROYED then
            Manager.Entities[id] = nil
            continue
        end
        local cached = npcRegistry[id]
        if not cached then Manager:Remove(id) continue end
        local head = cached.head
        if not head or not head.Parent then entity:Hide() continue end
        local hum = cached.humanoid
        if hum and hum.Health and hum.Health <= 0 then entity:Hide() continue end
        if root and (head.Position - root.Position).Magnitude > ESP_SETTINGS.MAX_DIST then entity:Hide() continue end
        entity:SetColor(ESP_SETTINGS[entity.Type] and ESP_SETTINGS[entity.Type].Color or Color3.new(1,1,1))
        local pos, onScreen = WorldToScreen(head.Position + Vector3.new(0, 1.5, 0))
        entity:Update(pos, onScreen)
    end
end)

