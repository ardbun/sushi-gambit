scheduler:add(TIMINGS.cooking, function()
    if not SETTINGS.Auto.Cooking.Enabled then return end
    local gui = PlayerGui:FindFirstChild("MakeSushiMinigame")
    if not gui then return end
    if memory_read("byte", gui.Address + ScreenGuiEnabled) == 1 then
        local bar = gui.MainFrame:FindFirstChild("CuttingBarFrame")
        if bar then
            local slider = bar.CutBar.Slider.AbsolutePosition
            local green = bar.CutBar.GreenBar.AbsolutePosition
            if slider.X >= green.X and slider.X <= green.X + bar.CutBar.GreenBar.AbsoluteSize.X then
                keypress(0x43) keyrelease(0x43)
            end
        end
    end
end)

scheduler:add(TIMINGS.washing, function()
    if not SETTINGS.Auto.Washing.Enabled then return end
    local gui = PlayerGui:FindFirstChild("DishWashingGui")
    if not gui or memory_read("byte", gui.Address + ScreenGuiEnabled) ~= 1 then return end
    local sink = game.Workspace.Kitchen:FindFirstChild("TheSink")
    if not sink or sink.DirtyDishAmount.Value == 0 then return end
    for _, v in ipairs(gui.MainFrame.QueueBarFrame.Queue.KeysHolder:GetChildren()) do
        if v.Name == "KeyTemplate" then
            local key = ({Q=0x51, E=0x45, R=0x52, F=0x46})[v:GetAttribute("Key")]
            if key then keypress(key) keyrelease(key) end
        end
    end
end)

