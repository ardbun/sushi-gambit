                        Manager:Add(addr, Entity.new(npc, Drawing.new("Text"), "Health Inspector"))
                    else
                        Manager.Entities[addr].Instance = npc
                    end
                elseif Manager.Entities[addr] and Manager.Entities[addr].Type == "Health Inspector" then
                    Manager:Remove(addr)
                end
            end
            
            -- Reset customer list at 8:00 AM
            local clock = PlayerGui:FindFirstChild("clockGui")
            if clock then
                local frame = clock:FindFirstChild("clockFrame")
                if frame then
                    local label = frame:FindFirstChild("clockLabel")
                    if label and label.Text == "08:00" then
                        customer_list = {}
                    end
                end
            end
        end)
    end
end

-- ESP Render Loop
RunService.Heartbeat:Connect(function()
    local root = Character and Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    for id, entity in pairs(Manager.Entities) do
        local cached = npc_cache[id]
        if not cached then
            Manager:Remove(id)
            continue
        end
        
        local head = cached.head
        if not head or not head.Parent then
            entity:Hide()
            continue
        end
        
        local cfg = ESP_SETTINGS[entity.Type]
        if not cfg or not cfg.Enabled then
            entity:Hide()
            continue
        end
        
        if (head.Position - root.Position).Magnitude > ESP_SETTINGS.MAX_DIST then
            entity:Hide()
            continue
        end
        
        entity:SetColor(cfg.Color)
        local pos, onScreen = WorldToScreen(head.Position + Vector3.new(0, 1.5, 0))
        if pos then
            entity:Update(pos, onScreen, true)
        end
    end
end)

-- Safe heartbeat connection
local heartbeatConn = nil
if RunService.Heartbeat then
    heartbeatConn = RunService.Heartbeat:Connect(function(dt)
        Scheduler:Update(dt)
    end)
elseif RunService.RenderStepped then
    heartbeatConn = RunService.RenderStepped:Connect(function(dt)
        Scheduler:Update(dt)
    end)
elseif RunService.Stepped then
    heartbeatConn = RunService.Stepped:Connect(function()
        Scheduler:Update(1/60)
    end)
else
    warn("No RunService event available - scheduler will not update")
    -- Fallback manual loop
    task.spawn(function()
        while true do
            task.wait(0.05)
            Scheduler:Update(0.05)
        end
    end)
end

if heartbeatConn then
    ConnectionManager:Add(heartbeatConn)
end
local charAddedConn = nil
if LocalPlayer.CharacterAdded then
    charAddedConn = LocalPlayer.CharacterAdded:Connect(function(char)
        Character = char
    end)
    ConnectionManager:Add(charAddedConn)
end

-- Note: ScriptContext.ScriptRemoved doesn't exist in all environments
-- Use BindToClose instead if available
if game.BindToClose then
    game:BindToClose(function()
        ConnectionManager:Cleanup()
        Windows:Delete()
    end)
end
print("[Sushi Gambit] Loaded with scheduler and memory leak fixes!")
