-- SAFETY WRAPPER
local function safeCall(fn, ...)
    local ok, err = pcall(fn, ...)
    if not ok then warn(err) end
end

-- SCHEDULER (Fixed - prevents memory leaks)
local Scheduler = {
    tasks = {},
    nextId = 1
}

function Scheduler:Add(interval, fn)
    local id = self.nextId
    self.nextId = self.nextId + 1
    table.insert(self.tasks, {
        id = id,
        interval = interval,
        time = 0,
        fn = fn
    })
    return id
end

function Scheduler:Remove(id)
    for i, task in ipairs(self.tasks) do
        if task.id == id then
            table.remove(self.tasks, i)
            break
        end
    end
end

function Scheduler:Update(dt)
    for i = #self.tasks, 1, -1 do
        local task = self.tasks[i]
        task.time = task.time + dt
        if task.time >= task.interval then
            task.time = task.time - task.interval
            safeCall(task.fn)
        end
    end
end

-- CONNECTION MANAGER (Prevents leaks)
local ConnectionManager = {
    connections = {},
    loops = {}
}

function ConnectionManager:Add(conn)
    if conn then
        table.insert(self.connections, conn)
    end
end

function ConnectionManager:CreateLoop(name, fn)
    local running = true
    local thread = task.spawn(function()
        while running do
            safeCall(fn)
            task.wait()
        end
    end)
    self.loops[name] = function() running = false end
    return self.loops[name]
end

function ConnectionManager:StopLoop(name)
    if self.loops[name] then
        self.loops[name]()
        self.loops[name] = nil
    end
end

function ConnectionManager:Cleanup()
    for _, conn in ipairs(self.connections) do
        safeCall(function() conn:Disconnect() end)
    end
    table.clear(self.connections)
    for name, stop in pairs(self.loops) do
        stop()
    end
    table.clear(self.loops)
end

