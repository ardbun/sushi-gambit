-- SAFE GET
local function safeGet(root, ...)
    local obj = root
    local keys = {...}
    for i = 1, #keys do
        if not obj then return nil end
        obj = obj:FindFirstChild(keys[i])
    end
    return obj
end

-- SCHEDULER
local Scheduler = {
    tasks = {}
}

function Scheduler:Add(interval, fn)
    table.insert(self.tasks, {
        time = 0,
        interval = interval,
        fn = fn
    })
end

function Scheduler:Update(dt)
    for _, task in ipairs(self.tasks) do
        task.time = task.time + dt
        if task.time >= task.interval then
            task.time = task.time - task.interval
            safeCall(task.fn)
        end
    end
end

-- CONNECTION MANAGER
local ConnectionManager = {
    conns = {}
}

function ConnectionManager:Add(conn)
    if conn then
        table.insert(self.conns, conn)
    end
end

function ConnectionManager:Cleanup()
    for _, c in ipairs(self.conns) do
        safeCall(function() c:Disconnect() end)
    end
    table.clear(self.conns)
end

-- DRAWING WINDOW
local Window = {
    elements = {},
    labels = {},
    position = Vector2.new(100, 100),
    size = Vector2.new(250, 130),
    radius = 10
}

function Window:Create()
    if not Drawing then return end
    
    local bgColor = Color3.fromRGB(15, 15, 15)
    local x, y = self.position.X, self.position.Y
    local w, h = self.size.X, self.size.Y
    local r = self.radius
    
    local function addRect(pos, size)
        local rect = Drawing.new("Square")
        rect.Position = pos
        rect.Size = size
        rect.Color = bgColor
        rect.Filled = true
        rect.Visible = false
        rect.Thickness = 0
        table.insert(self.elements, rect)
        return rect
    end
    
    local function addCircle(pos)
        local circle = Drawing.new("Circle")
        circle.Position = pos
        circle.Radius = r
        circle.Color = bgColor
        circle.Filled = true
        circle.Visible = false
        circle.NumSides = 64
        table.insert(self.elements, circle)
        return circle
    end
    
    self.topLeft = addCircle(Vector2.new(x + r, y + r))
    self.topRight = addCircle(Vector2.new(x + w - r, y + r))
    self.bottomLeft = addCircle(Vector2.new(x + r, y + h - r))
    self.bottomRight = addCircle(Vector2.new(x + w - r, y + h - r))
    self.verticalFill = addRect(Vector2.new(x + r, y), Vector2.new(w - 2 * r, h))
    self.horizontalFill = addRect(Vector2.new(x, y + r), Vector2.new(w, h - 2 * r))
    
    self.title = Drawing.new("Text")
    self.title.Text = "Sushi Gambit"
    self.title.Size = 12
    self.title.Position = Vector2.new(x + 12, y + 15)
    self.title.Color = Color3.fromRGB(255, 0, 0)
    self.title.Visible = false
    self.title.Outline = true
    table.insert(self.elements, self.title)
end

function Window:AddLabel(text, color)
    local label = Drawing.new("Text")
    label.Text = text
    label.Size = 14
    label.Color = color or Color3.new(1, 1, 1)
    label.Visible = true
    label.Outline = true
    label.Center = false
    table.insert(self.labels, label)
    
self:Update()
    
    local handle = {}
    handle.setText = function(newText) label.Text = newText end
    handle.remove = function()
        label:Remove()
        for i, l in ipairs(self.labels) do
            if l == label then
                table.remove(self.labels, i)
                break
            end
        end
        self:RefreshPositions()
    end
    return handle
end

function Window:RefreshPositions()
    for i, label in ipairs(self.labels) do
        label.Position = self.position + Vector2.new(12, 35 + (i - 1) * 18)
    end
    
    local neededHeight = 35 + #self.labels * 18 + 10
    self.size = Vector2.new(self.size.X, math.max(neededHeight, 130))
    -- REMOVE THIS LINE:
    -- self:UpdateGeometry()
end

function Window:UpdateGeometry()
    self:UpdateGeometryNoRecurse()
    self:RefreshPositionsNoRecurse()  -- Call non-recursive version
end

function Window:UpdateGeometryNoRecurse()
    local x, y = self.position.X, self.position.Y
    local w, h = self.size.X, self.size.Y
    local r = self.radius
    
    if self.topLeft then
        self.topLeft.Position = Vector2.new(x + r, y + r)
        self.topRight.Position = Vector2.new(x + w - r, y + r)
        self.bottomLeft.Position = Vector2.new(x + r, y + h - r)
        self.bottomRight.Position = Vector2.new(x + w - r, y + h - r)
        self.verticalFill.Position = Vector2.new(x + r, y)
        self.verticalFill.Size = Vector2.new(w - 2 * r, h)
        self.horizontalFill.Position = Vector2.new(x, y + r)
        self.horizontalFill.Size = Vector2.new(w, h - 2 * r)
        self.title.Position = Vector2.new(x + 12, y + 15)
    end
end

function Window:RefreshPositionsNoRecurse()
function Window:Update()
    self:UpdateGeometryNoRecurse()
    self:RefreshPositionsNoRecurse()
end
    for i, label in ipairs(self.labels) do
        label.Position = self.position + Vector2.new(12, 35 + (i - 1) * 18)
    end
end

function Window:Show(visible)
    State.Window.Visible = visible
    for _, elem in ipairs(self.elements) do
        elem.Visible = visible
    end
    for _, label in ipairs(self.labels) do
        label.Visible = visible
    end
    self.title.Visible = visible
end

-- ESP SYSTEM
local ESP = {
    entities = {}
}

function ESP:GetNPCType(npc)
    local isPolice = npc:GetAttribute("Cop") == true
    local isArmed = npc:GetAttribute("WeaponOfChoice") == "Knife"
    local isCritic = npc:GetAttribute("Critic") == true
    local isInspector = npc:GetAttribute("Behavior") == "Inspector"
    local isDasher = npc:GetAttribute("CurrentState") == "WaitingInLine"
    
    if State.ESP.ShowHealthInspector and isInspector then
        return "HealthInspector", State.ESP.Colors.HealthInspector
    elseif State.ESP.ShowCritic and isCritic then
        return "Critic", State.ESP.Colors.Critic
    elseif State.ESP.ShowPolice and isPolice then
        return "Police", State.ESP.Colors.Police
    elseif State.ESP.ShowArmed and isArmed then
        return "Armed", State.ESP.Colors.Armed
    elseif State.ESP.ShowDasher and isDasher then
        return "Dasher", State.ESP.Colors.Dasher
    end
    
    return nil, nil
end

function ESP:Create(npc)
    if not npc or not Drawing then return end
    
    local id = tostring(npc)
    if self.entities[id] then return end
    
    local head = npc:FindFirstChild("Head")
    if not head then return end
    
    local npcType, color = self:GetNPCType(npc)
    if not npcType then return end
    
    local label = Drawing.new("Text")
    label.Size = 14
    label.Outline = true
    label.Text = npcType
    label.Color = color
    label.Visible = false
    
    self.entities[id] = {
        npc = npc,
        head = head,
        label = label,
        npcType = npcType
    }
end

function ESP:UpdateNPC(npc)
    local id = tostring(npc)
    local ent = self.entities[id]
    if not ent then return end
    
    local npcType, color = self:GetNPCType(npc)
    if npcType and ent.npcType ~= npcType then
        ent.label.Text = npcType
        ent.label.Color = color
        ent.npcType = npcType
    elseif not npcType then
        self:Destroy(npc)
    end
end

function ESP:Destroy(npc)
    local id = tostring(npc)
    local ent = self.entities[id]
    if ent then
        safeCall(function() ent.label:Remove() end)
        self.entities[id] = nil
    end
end

function ESP:Update()
    if not State.ESP.Enabled then return end
    
    local cam = workspace.CurrentCamera
    if not cam then return end
    
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local rootPos = root.Position
    local maxDist = State.ESP.MaxDist
    
    for _, ent in pairs(self.entities) do
        if not ent.head or not ent.head:IsDescendantOf(game) then
            ent.label.Visible = false
        else
            local dist = (ent.head.Position - rootPos).Magnitude
            if dist <= maxDist then
                local pos, onScreen = cam:WorldToViewportPoint(ent.head.Position + Vector3.new(0, 1.5, 0))
                if onScreen then
                    ent.label.Position = Vector2.new(pos.X, pos.Y)
                    ent.label.Visible = true
                else
                    ent.label.Visible = false
                end
            else
                ent.label.Visible = false
            end
        end
    end
end

-- NPC MANAGER
local NPCManager = {
    npcs = {}
}

function NPCManager:Init(folder)
    if not folder then return end
    
    local function track(npc)
        if not npc or not npc:IsA("Model") then return end
        self.npcs[tostring(npc)] = npc
        ESP:Create(npc)
        
        local attrs = {"Cop", "Critic", "Behavior", "CurrentState", "WeaponOfChoice"}
        for _, attr in ipairs(attrs) do
            local signal = npc:GetAttributeChangedSignal(attr)
            if signal then
                local conn = signal:Connect(function()
                    ESP:UpdateNPC(npc)
                end)
                ConnectionManager:Add(conn)
            end
        end
    end  -- <-- This closes the track function
    
    for _, npc in ipairs(folder:GetChildren()) do
        track(npc)
    end
    
    ConnectionManager:Add(folder.ChildAdded:Connect(track))
    ConnectionManager:Add(folder.ChildRemoved:Connect(function(npc)
        self.npcs[tostring(npc)] = nil
        ESP:Destroy(npc)
    end))
end  -- <-- This closes the Init function

