-- SCHEDULER SYSTEM (replaces all timers)
local Scheduler = {}
Scheduler.tasks = {}

function Scheduler:add(interval, fn)
    table.insert(self.tasks, { interval = interval, time = 0, fn = fn })
end

function Scheduler:update(dt)
    for _, task in ipairs(self.tasks) do
        task.time = task.time + dt
        if task.time >= task.interval then
            task.time = 0
            task.fn()
        end
    end
end

local scheduler = setmetatable({}, { __index = Scheduler })
scheduler.tasks = {}

-- SINGLE HEARTBEAT WITH SCHEDULER
RunService.Heartbeat:Connect(function(dt)
    scheduler:update(dt)
end)

