-- Drag handling (SAFE VERSION)
local function SetupDrag()
    if not UserInputService then
        warn("UserInputService not available - drag disabled")
        return
    end
    
    local dragging = false
    local dragOffset = Vector2.new(0, 0)
    
    -- Safe InputBegan
    if UserInputService.InputBegan then
        local onInputBegan = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if not input then return end
            if input.UserInputType and input.UserInputType == Enum.UserInputType.MouseButton1 then
                local mousePos = UserInputService:GetMouseLocation()
                if not mousePos then return end
                
                local px, py = Windows.Position.X, Windows.Position.Y
                local w, h = Windows.Size.X, Windows.Size.Y
                
                if mousePos.X >= px and mousePos.X <= px + w and mousePos.Y >= py and mousePos.Y <= py + h then
                    dragging = true
                    dragOffset = Vector2.new(mousePos.X - px, mousePos.Y - py)
                end
            end
        end)
        ConnectionManager:Add(onInputBegan)
    end
    
    -- Safe InputEnded
    if UserInputService.InputEnded then
        local onInputEnded = UserInputService.InputEnded:Connect(function(input)
            if not input then return end
            if input.UserInputType and input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        ConnectionManager:Add(onInputEnded)
    end
    
    -- Safe InputChanged (if available)
    if UserInputService.InputChanged then
        local onInputChanged = UserInputService.InputChanged:Connect(function(input)
            if not dragging then return end
            if not input then return end
            if input.UserInputType and input.UserInputType == Enum.UserInputType.MouseMovement then
                local mousePos = UserInputService:GetMouseLocation()
                if mousePos then
                    Windows:Edit(Vector2.new(mousePos.X - dragOffset.X, mousePos.Y - dragOffset.Y))
                end
            end
        end)
        ConnectionManager:Add(onInputChanged)
    else
        warn("InputChanged not available - drag movement disabled")
    end
end

