local STATE = {ACTIVE = 1, DESTROYED = 2}

local Entity = {}
Entity.__index = Entity

function Entity.new(instance, textObj, typeName)
    return setmetatable({
        Instance = instance,
        Text = textObj,
        Type = typeName,
        State = STATE.ACTIVE
    }, Entity)
end

function Entity:Update(pos, onScreen)
    if self.State == STATE.DESTROYED then return end
    self.Text.Visible = onScreen
    if onScreen then self.Text.Position = pos end
end

function Entity:Destroy()
    if self.State == STATE.DESTROYED then return end
    self.State = STATE.DESTROYED
    pcall(function() self.Text:Remove() end)
end

local Manager = {Entities = {}, List = {}}

function Manager:Add(id, ent)
    self.Entities[id] = ent
    table.insert(self.List, ent)
end

function Manager:Remove(id)
    local ent = self.Entities[id]
    if ent then
        ent:Destroy()
        self.Entities[id] = nil
        for i, v in ipairs(self.List) do
            if v == ent then table.remove(self.List, i) break end
        end
    end
end

local npcCache = {}
local customer_list = {}
local folder = game.Workspace.NpcDestination.SpawnedNPCs

local heartbeatConn
local lastLabelUpdate = 0
local lastNPCScan = 0

heartbeatConn = RunService.Heartbeat:Connect(function(dt)
    local now = tick()

if now - lastLabelUpdate > 0.2 then
    lastLabelUpdate = now
    if dayLabel then dayLabel:SetText("day: "..GameData.CurrentDay.Value) end
    if companyMoneyLabel then companyMoneyLabel:SetText("money: "..string.format("%.2f", GameData.CompanyMoney.Value)) end
    if vegLabel then vegLabel:SetText("veggies: "..GameData.Ingredients.IngredientsStorage.Vegetables.Stock.Value.."/"..GameData.Ingredients.IngredientsStorage.Vegetables.MaxStock.Value) end
    if fishLabel then fishLabel:SetText("fish: "..GameData.Ingredients.IngredientsStorage.AssortedFish.Stock.Value.."/"..GameData.Ingredients.IngredientsStorage.AssortedFish.MaxStock.Value) end
    if humanFleshLabel then humanFleshLabel:SetText("meat: "..GameData.Ingredients.IngredientsStorage.HumanFlesh.Stock.Value.."/"..GameData.Ingredients.IngredientsStorage.HumanFlesh.MaxStock.Value) end
    if riceLabel then riceLabel:SetText("rice: "..GameData.Ingredients.IngredientsStorage.Rice.Stock.Value.."/"..GameData.Ingredients.IngredientsStorage.Rice.MaxStock.Value) end
end

    if now - lastNPCScan > 0.4 then
        lastNPCScan = now
        local seen = {}

        for _, npc in ipairs(folder:GetChildren()) do
            local addr = npc.Address
            seen[addr] = true

            if not npcCache[addr] then
                npcCache[addr] = {
                    inst = npc,
                    head = npc:FindFirstChild("Head"),
                    humanoid = npc:FindFirstChild("Humanoid")
                }
            end
        end

        for addr in pairs(npcCache) do
            if not seen[addr] or not npcCache[addr].inst:IsDescendantOf(game) then
                customer_list[addr] = nil
                Manager:Remove(addr)
                npcCache[addr] = nil
            end
        end
    end

    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    for addr, cached in pairs(npcCache) do
        local npc = cached.inst
        if not npc then continue end

        if SETTINGS.Cheat.Instant.SeatCustomer.Enabled and npc:GetAttribute("CurrentState") == "WaitingInLine" and not customer_list[addr] then
            local prompt = safePath(npc, "Torso", "WaitProximityPrompt")
            if prompt then
                memory_write("float", prompt.Address + HoldDuration, 0)
                customer_list[addr] = true
            end
        end

        local ent = Manager.Entities[addr]
        local cfg = ESP_SETTINGS[ent and ent.Type or ""]

        if ent and (not cfg or not cfg.Enabled) then
            Manager:Remove(addr)
        elseif cfg and cfg.Enabled then
            if not ent then
                local t = Drawing.new("Text")
                t.Outline = true
                t.Size = 18
                ent = Entity.new(npc, t, "Unknown")
                Manager:Add(addr, ent)
            end

            ent.Instance = npc
            local head = cached.head
            if head and head.Parent and (not cached.humanoid or cached.humanoid.Health > 0) then
                if root and (head.Position - root.Position).Magnitude > ESP_SETTINGS.MAX_DIST then
                    ent:Update(nil, false)
                else
                    local pos, onScreen = WorldToScreen(head.Position + Vector3.new(0, 1.5, 0))
                    ent.Text.Color = cfg.Color
                    ent:Update(pos, onScreen)
                end
            else
                ent:Update(nil, false)
            end
        end
    end

    if SETTINGS.Cheat.Spoof.Greenbar.Enabled then
        PlayerStats.EffectiveCookingLevel.Value = 1000
        PlayerStats.NoIngredientUseChance.Value = 1
    end
    if SETTINGS.Cheat.Instant.CleanDish.Enabled then
        PlayerStats.EffectiveCleaningLevel.Value = 9999
    end
    if SETTINGS.Cheat.Spoof.SpongeEffectiveness.Enabled then
        PlayerStats.SpongeEffectiveness.Value = 9999
    end
end)

